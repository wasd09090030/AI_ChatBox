# ===== API Keys =====
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# ===== Model =====
DEFAULT_LLM_PROVIDER=openai
DEFAULT_MODEL=gpt-4-turbo
DEFAULT_TEMPERATURE=0.95
DEFAULT_MAX_TOKENS=4000

# ===== Retrieval =====
TOP_K_RESULTS=5
SIMILARITY_THRESHOLD=0.7

# ===== Storage (推荐) =====
# sqlite | json
STORAGE_BACKEND=sqlite
STORAGE_SHADOW_WRITE_JSON=false
STORAGE_AUTO_MIGRATE_JSON_TO_SQLITE=true
# 相对路径会自动解析到 story_rag_service 目录下
WORLDS_JSON_PATH=./data/worlds.json
STORIES_JSON_PATH=./data/stories.json
DATABASE_PATH=./data/chatbox.db

# ===== Chroma / HF =====
CHROMA_PERSIST_DIRECTORY=./data/chroma_db
COLLECTION_NAME=story_lorebook
HUGGINGFACE_CACHE_DIR=./data/huggingface_cache

# ===== Service =====
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# ===== LangGraph Checkpointer =====
LANGGRAPH_CHECKPOINT_BACKEND=sqlite
LANGGRAPH_CHECKPOINT_SQLITE_PATH=./data/langgraph_checkpoints.db

# ===== RP Feature Flags (Gray Release) =====
RP_STORY_STATE_ENABLED=true
RP_SUMMARY_MEMORY_ENABLED=true
RP_DEBUG_PAYLOAD_ENABLED=true
