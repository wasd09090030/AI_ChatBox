    "@vueuse/core": "^13.9.0",
    "ai": "^5.0.100",
    "autoprefixer": "^10.4.21",
    "axios": "^1.13.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.3.0",
    "echarts": "^6.0.0",
    "highlight.js": "^11.11.1",
    "lucide-vue-next": "^0.575.0",
    "mammoth": "^1.11.0",
    "marked": "^16.4.1",
    "pdfjs-dist": "^5.4.449",
    "pinia": "^3.0.3",
    "postcss": "^8.5.6",
    "radix-vue": "^1.9.17",
